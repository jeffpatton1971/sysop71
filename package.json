{
  "name": "sysop71-react-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:content && vite",
    "build:content": "tsx scripts/build-content.ts",
    "content:validate": "tsx scripts/validate-content.ts",
    "content:validate:strict": "tsx scripts/validate-content.ts --strict",
    "content:contract:migrate": "tsx scripts/migrate-contract-frontmatter.ts",
    "content:contract:migrate:write": "tsx scripts/migrate-contract-frontmatter.ts --write",
    "taxonomy:normalize": "tsx scripts/normalize-taxonomy.ts",
    "taxonomy:normalize:write": "tsx scripts/normalize-taxonomy.ts --write",
    "entities:normalize": "tsx scripts/normalize-entities.ts",
    "entities:normalize:write": "tsx scripts/normalize-entities.ts --write",
    "normalize:posts": "tsx scripts/normalize-post-frontmatter.ts",
    "assets:migrate": "tsx scripts/migrate-image-storage.ts",
    "assets:migrate:write": "tsx scripts/migrate-image-storage.ts --write",
    "build": "npm run build:content && tsc -b && vite build",
    "build:content:incremental": "tsx scripts/build-content.ts --from-plan",
    "publish:plan": "tsx scripts/plan-publish.ts",
    "publish:media:dry-run": "npm run publish:plan && tsx scripts/publish-media.ts --dry-run",
    "publish:media": "npm run publish:plan && tsx scripts/publish-media.ts --write",
    "publish:prepare": "tsx scripts/plan-publish.ts --write-source",
    "publish:cleanup-media": "tsx scripts/cleanup-published-media.ts",
    "publish:cleanup-media:write": "tsx scripts/cleanup-published-media.ts --write",
    "publish:content": "npm run build:content && tsx scripts/publish-content.ts",
    "publish:content:dry-run": "npm run build:content && tsx scripts/publish-content.ts --dry-run",
    "publish:content:incremental": "npm run build:content:incremental && tsx scripts/publish-content.ts --from-plan",
    "publish:content:incremental:dry-run": "npm run build:content:incremental && tsx scripts/publish-content.ts --dry-run --from-plan",
    "preview": "vite preview",
    "test": "npm run test:site",
    "test:site": "npm run test:site:build && npm run test:site:e2e",
    "test:site:build": "npm run build",
    "test:site:e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "ffmpeg-static": "^5.3.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
